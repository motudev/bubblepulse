PORT=8080
# Pooled mode requires a NON-superuser role (superusers silently bypass RLS;
# the app refuses to start). docker/postgres/init.sql creates bubblepulse_app.
# Docker Compose maps the container's 5432 to host port 5001 (docker-compose.yml).
DATABASE_URL=postgres://bubblepulse_app:bubblepulse_app@localhost:5001/bubblepulse?sslmode=disable
TEST_DATABASE_URL=postgres://bubblepulse_app:bubblepulse_app@localhost:5001/bubblepulse_test?sslmode=disable

# Tenancy deployment mode:
#   pooled (default) — shared multi-tenant SaaS; RLS isolates organizations.
#   siloed           — dedicated single-tenant deployment; the same schema runs
#                      with the RLS bypass condition active.
TENANCY_MODE=pooled

OIDC_ISSUER_URL=https://slack.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/auth/callback

# Origin of the frontend SPA. After login/logout the backend redirects here.
# In production, leave empty — the backend and frontend share the same origin.
FRONTEND_URL=http://localhost:5200

# Slack Bot integration — find these in your Slack app settings.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
